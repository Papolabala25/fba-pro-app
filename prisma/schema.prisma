generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Analysis {
  id                    Int      @id @default(autoincrement())
  asin                  String
  buyBoxPrice           Float?
  currentRank           Int?
  avg30dRank            Int?
  estimatedMonthlySales Int?
  offersCount           Int?
  pressureIndex         Float?
  trend                 String?
  arogaScore            Int
  verdict               String
  createdAt             DateTime @default(now())
}
